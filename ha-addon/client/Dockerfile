# CF.3: digest-pinned base so the client image that ships to GHCR has
# a reproducible supply-chain anchor. The index digest below is a
# manifest list covering linux/amd64 and linux/arm64 both — multi-arch
# builds pick the right variant automatically at pull time.
#
# Refresh at every release after verifying the new digest's CVE
# bulletin:
#   docker buildx imagetools inspect python:3.13-slim | grep '^Digest:'
# Paste that digest here.
# Last refreshed: 2026-07-17 (#240 python 3.11->3.13 base bump, in lockstep
# with ha-addon/Dockerfile — both must match so a stale client doesn't
# drift onto a CVE window the server has already cleared).
FROM python:3.13-slim@sha256:6771159cd4fa5d9bba1258caf0b82e6b73458c694d178ad97c5e925c2d0e1a91
# Bug #6 (1.6.1): `iputils-ping` is required by the OTA network-diagnostics
# probe in client.py — without it the probe logs `Ping: [Errno 2] No such
# file or directory: 'ping'` every time an OTA upload fails, which is
# noise that hides the real cause. ICMP sockets from Python require
# CAP_NET_RAW, so using a binary is simpler than pulling in an ICMP
# library that would need a capability grant on top of the AppArmor
# profile.
RUN apt-get update && apt-get install -y gcc libffi-dev libssl-dev git iputils-ping && rm -rf /var/lib/apt/lists/*
WORKDIR /app
# E.1: hash-pinned install from the lockfile generated by
# scripts/refresh-deps.sh. The .txt is the human-edited input; .lock is the
# fully-resolved hash-locked artifact.
COPY requirements.lock .
RUN pip install --no-cache-dir --require-hashes -r requirements.lock
COPY *.py .
# IMAGE_VERSION is intentionally SEPARATE from CLIENT_VERSION (the source code
# version). Workers auto-update their source code from the server in place via
# os.execv, but the Docker image itself (system packages, Python, requirements)
# can't change that way. When the image changes, this number should be bumped
# so the server can detect workers running a stale image and prompt a rebuild.
COPY IMAGE_VERSION .
VOLUME /esphome-versions
# Store PlatformIO toolchains inside the persistent esphome-versions volume
# so they survive container recreations (avoid re-downloading toolchains each time).
ENV PLATFORMIO_CORE_DIR=/esphome-versions/platformio
ENTRYPOINT ["python", "client.py"]
